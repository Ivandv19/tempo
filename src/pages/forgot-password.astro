---
import Layout from '../layouts/Layout.astro';
import ForgotPasswordForm from '../components/Auth/ForgotPasswordForm';
import { ui } from '../i18n/ui';

const t = ui.es;
---

<Layout title="Recuperar Contraseña | Tempo">
	<div class="min-h-screen flex items-center justify-center py-8 sm:py-12 px-3 sm:px-6 lg:px-8">
		<ForgotPasswordForm
			client:only="react"
			translations={{
				title: t["auth.forgot.title"],
				subtitle: t["auth.forgot.subtitle"],
				sent: t["auth.forgot.sent"],
				btn: t["auth.forgot.btn"],
				emailLabel: t["auth.email.label"],
				emailPlaceholder: t["auth.email.placeholder"],
				loading: t["auth.loading"],
				backHome: t["auth.backHome"],
			}}
			redirectPath="/"
		/>
	</div>
</Layout>
